@page "/medewerkers"
@rendermode InteractiveServer
@using Novo.Planning.Domain.Models
@using Novo.Planning.Web.Features.Persons.Services
@using Novo.Planning.Web.Components.Shared
@inject IPersonService PersonService
@inject NavigationManager Navigation

<PageTitle>Medewerkers</PageTitle>

<h3>Medewerkers</h3>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="AddPerson">
        <span class="bi bi-plus-circle" aria-hidden="true"></span> Nieuwe medewerker
    </button>
</div>

@if (_persons is null)
{
    <p><em>Laden...</em></p>
}
else if (_persons.Count == 0)
{
    <p>Geen medewerkers gevonden.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Naam</th>
                <th>Nederlands</th>
                <th>Pools</th>
                <th>Vrije dagen</th>
                <th>Vaardigheden</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var person in _persons)
            {
                <tr @onclick="() => EditPerson(person.Id)" style="cursor: pointer;">
                    <td>@person.Name</td>
                    <td>@(person.SpeaksDutch ? "Ja" : "Nee")</td>
                    <td>@(person.SpeaksPolish ? "Ja" : "Nee")</td>
                    <td>@FormatDaysOff(person.DefaultDaysOff)</td>
                    <td>@FormatSkillSummary(person.Skills)</td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => ConfirmDelete(person)"
                                @onclick:stopPropagation="true">
                            Verwijderen
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<ConfirmDialog Title="Medewerker verwijderen"
               Message="@_deleteMessage"
               ConfirmText="Verwijderen"
               IsVisible="_showDeleteDialog"
               OnConfirm="DeleteConfirmed"
               OnCancel="DeleteCancelled" />

@code {
    private IReadOnlyList<Person>? _persons;
    private Person? _personToDelete;
    private bool _showDeleteDialog;
    private string _deleteMessage = string.Empty;

    private static readonly Dictionary<DayOfWeek, string> DutchDayNames = new()
    {
        [DayOfWeek.Monday] = "Ma",
        [DayOfWeek.Tuesday] = "Di",
        [DayOfWeek.Wednesday] = "Wo",
        [DayOfWeek.Thursday] = "Do",
        [DayOfWeek.Friday] = "Vr",
        [DayOfWeek.Saturday] = "Za",
        [DayOfWeek.Sunday] = "Zo",
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadPersons();
    }

    private async Task LoadPersons()
    {
        _persons = await PersonService.GetAllAsync();
    }

    private void AddPerson()
    {
        Navigation.NavigateTo("/medewerkers/nieuw");
    }

    private void EditPerson(string id)
    {
        Navigation.NavigateTo($"/medewerkers/{id}");
    }

    private void ConfirmDelete(Person person)
    {
        _personToDelete = person;
        _deleteMessage = $"Weet u zeker dat u '{person.Name}' wilt verwijderen?";
        _showDeleteDialog = true;
    }

    private async Task DeleteConfirmed()
    {
        if (_personToDelete is not null)
        {
            await PersonService.DeleteAsync(_personToDelete.Id);
            _personToDelete = null;
            _showDeleteDialog = false;
            await LoadPersons();
        }
    }

    private void DeleteCancelled()
    {
        _personToDelete = null;
        _showDeleteDialog = false;
    }

    private static string FormatDaysOff(HashSet<DayOfWeek> daysOff)
    {
        if (daysOff.Count == 0) return "-";

        var ordered = daysOff
            .OrderBy(d => d == DayOfWeek.Sunday ? 7 : (int)d)
            .Select(d => DutchDayNames.GetValueOrDefault(d, d.ToString()));

        return string.Join(", ", ordered);
    }

    private static string FormatSkillSummary(Dictionary<string, SkillLevel> skills)
    {
        if (skills.Count == 0) return "-";

        var capable = skills.Count(s => s.Value != SkillLevel.Cannot);
        return $"{capable}/{skills.Count} taken";
    }
}
