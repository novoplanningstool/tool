@page "/medewerkers/nieuw"
@page "/medewerkers/{Id}"
@rendermode InteractiveServer
@using Novo.Planning.Domain.Models
@using Novo.Planning.Web.Features.Persons.Services
@using Novo.Planning.Web.Features.Persons.Components
@inject IPersonService PersonService
@inject NavigationManager Navigation

<PageTitle>@(_isNew ? "Nieuwe medewerker" : _person.Name)</PageTitle>

<h3>@(_isNew ? "Nieuwe medewerker" : _person.Name)</h3>

@if (_loading)
{
    <p><em>Laden...</em></p>
}
else if (_notFound)
{
    <div class="alert alert-warning">Medewerker niet gevonden.</div>
    <button class="btn btn-secondary" @onclick="GoBack">Terug naar overzicht</button>
}
else
{
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success">@_successMessage</div>
    }

    <div class="row">
        <div class="col-md-6">
            <PersonForm Person="_person" />
        </div>
    </div>

    <div class="mt-4">
        <h4>Vaardigheden</h4>
        <SkillMatrixEditor Skills="_person.Skills" SkillsChanged="OnSkillsChanged" />
    </div>

    <div class="mt-4 mb-4">
        <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
            @(_saving ? "Opslaan..." : "Opslaan")
        </button>
        <button class="btn btn-secondary ms-2" @onclick="GoBack">Annuleren</button>
    </div>
}

@code {
    [Parameter] public string? Id { get; set; }

    private Person _person = new();
    private bool _isNew;
    private bool _loading = true;
    private bool _notFound;
    private bool _saving;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        _isNew = string.IsNullOrEmpty(Id) || Id == "nieuw";

        if (!_isNew)
        {
            var existing = await PersonService.GetByIdAsync(Id!);
            if (existing is null)
            {
                _notFound = true;
            }
            else
            {
                _person = existing;
            }
        }

        _loading = false;
    }

    private void OnSkillsChanged(Dictionary<string, SkillLevel> skills)
    {
        _person.Skills = skills;
    }

    private async Task Save()
    {
        _saving = true;
        _errorMessage = null;
        _successMessage = null;

        var (success, error) = await PersonService.SaveAsync(_person);

        if (success)
        {
            if (_isNew)
            {
                Navigation.NavigateTo($"/medewerkers/{_person.Id}");
            }
            else
            {
                _successMessage = "Medewerker opgeslagen.";
            }
        }
        else
        {
            _errorMessage = error;
        }

        _saving = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/medewerkers");
    }
}
