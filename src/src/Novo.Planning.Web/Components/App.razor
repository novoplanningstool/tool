<!DOCTYPE html>
<html lang="nl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Novo.Planning.Web.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        window.novoDragDrop = {
            _worker: null,
            _source: null,
            _column: null,
            _dotNetRef: null,

            registerDropHandler: function (dotNetRef) {
                this._dotNetRef = dotNetRef;
            },
            unregisterDropHandler: function () {
                this._dotNetRef = null;
            },
            flashReject: function (taskName) {
                var el = document.querySelector('[data-drop-task="' + taskName + '"]');
                if (el) {
                    el.classList.add('drop-rejected');
                    setTimeout(function () { el.classList.remove('drop-rejected'); }, 500);
                }
            }
        };

        // Track drag data on dragstart
        document.addEventListener('dragstart', function (e) {
            var el = e.target.closest('[draggable="true"]');
            if (!el) return;

            var dd = window.novoDragDrop;
            var col = el.getAttribute('data-drag-column');
            if (col) {
                dd._column = col;
                dd._worker = null;
                dd._source = null;
            } else {
                dd._worker = el.getAttribute('data-drag-worker') || null;
                dd._source = el.getAttribute('data-drag-source') || null;
                dd._column = null;
            }
            e.dataTransfer.setData('text/plain', '');
            e.dataTransfer.effectAllowed = 'move';
        });

        // Allow dropping on valid targets
        document.addEventListener('dragover', function (e) {
            if (e.target.closest('[data-drop-task], [data-drop-zone], [data-drop-side]')) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
            }
        });

        // Drag-over visual feedback
        document.addEventListener('dragenter', function (e) {
            var taskEl = e.target.closest('[data-drop-task]');
            if (taskEl) {
                taskEl.classList.add('drag-over');
                return;
            }
            var zoneEl = e.target.closest('[data-drop-zone]');
            if (zoneEl) {
                zoneEl.classList.add('drag-over');
            }
        });

        document.addEventListener('dragleave', function (e) {
            var related = e.relatedTarget;
            var taskEl = e.target.closest('[data-drop-task]');
            if (taskEl) {
                if (!related || !taskEl.contains(related)) {
                    taskEl.classList.remove('drag-over');
                }
                return;
            }
            var zoneEl = e.target.closest('[data-drop-zone]');
            if (zoneEl) {
                if (!related || !zoneEl.contains(related)) {
                    zoneEl.classList.remove('drag-over');
                }
            }
        });

        document.addEventListener('dragend', function () {
            document.querySelectorAll('.drag-over').forEach(function (el) {
                el.classList.remove('drag-over');
            });
        });

        // Handle drop entirely in JS, then call .NET
        document.addEventListener('drop', function (e) {
            document.querySelectorAll('.drag-over').forEach(function (el) {
                el.classList.remove('drag-over');
            });

            var dd = window.novoDragDrop;
            if (!dd._dotNetRef) return;

            var target = e.target;

            // 1. Drop on a task column
            var taskEl = target.closest('[data-drop-task]');
            if (taskEl) {
                e.preventDefault();
                var taskName = taskEl.getAttribute('data-drop-task');

                if (dd._column) {
                    dd._dotNetRef.invokeMethodAsync('OnDropColumnOnTask', dd._column, taskName);
                } else if (dd._worker) {
                    dd._dotNetRef.invokeMethodAsync('OnDropTask', taskName, dd._worker, dd._source || null);
                }
                dd._worker = null; dd._source = null; dd._column = null;
                return;
            }

            // 2. Drop on unassigned/absent zone
            var zoneEl = target.closest('[data-drop-zone]');
            if (zoneEl) {
                e.preventDefault();
                var zone = zoneEl.getAttribute('data-drop-zone');

                if (dd._worker) {
                    if (zone === 'unassigned') {
                        dd._dotNetRef.invokeMethodAsync('OnDropUnassigned', dd._worker, dd._source || null);
                    } else if (zone === 'absent') {
                        dd._dotNetRef.invokeMethodAsync('OnDropAbsent', dd._worker, dd._source || null);
                    }
                }
                dd._worker = null; dd._source = null; dd._column = null;
                return;
            }

            // 3. Drop on a side container (column reorder across sides)
            var sideEl = target.closest('[data-drop-side]');
            if (sideEl) {
                e.preventDefault();
                var side = sideEl.getAttribute('data-drop-side');

                if (dd._column) {
                    dd._dotNetRef.invokeMethodAsync('OnDropColumnOnSide', dd._column, side);
                }
                dd._worker = null; dd._source = null; dd._column = null;
                return;
            }
        });
    </script>
</body>

</html>
